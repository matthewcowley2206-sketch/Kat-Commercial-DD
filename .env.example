# Database — Postgres required (use Neon, Supabase, or Vercel Postgres)
# Example Neon: postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/kat_commercial_dd?sslmode=require"

# Security - generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-here"
AUDIT_SECRET="your-audit-chain-secret-here"

# Application
NEXT_PUBLIC_APP_NAME="Kat Commercial DD"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Optional: store uploads in database (auto-enabled on Vercel)
# STORE_FILES_IN_DB="true"
