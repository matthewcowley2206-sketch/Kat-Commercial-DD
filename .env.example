# Database
# Local dev (SQLite):
DATABASE_URL="file:./dev.db"
# Vercel Postgres auto-sets POSTGRES_PRISMA_URL — no DATABASE_URL needed
# Or use Neon/Supabase:
# DATABASE_URL="postgresql://user:password@host:5432/kat_commercial_dd?sslmode=require"

# Optional: Geoapify for premium AU address autocomplete (free tier: 3000/day)
# Without this, OpenStreetMap is used automatically
# GEOAPIFY_API_KEY="your-geoapify-key"

# Security - generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-here"
AUDIT_SECRET="your-audit-chain-secret-here"

# Application
NEXT_PUBLIC_APP_NAME="Kat Commercial DD"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Optional: store uploads in database (auto-enabled on Vercel)
# STORE_FILES_IN_DB="true"
